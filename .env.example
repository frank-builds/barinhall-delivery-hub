VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sprint D1 — bootstrap admin (dev / scaffold mode only).
# When the user_profiles table is missing or unreachable, any user signing in
# with this exact email is treated as platform_admin so the admin module is
# usable without a database. Once the migration is applied and a real
# user_profiles row exists, this variable becomes redundant.
# Leave blank in production.
VITE_PLATFORM_ADMIN_EMAIL=

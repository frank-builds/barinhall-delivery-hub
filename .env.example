VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sprint D1.1 — bootstrap admin override (dev only).
#
# Set this to the email of the user who should always be treated as
# platform_admin, REGARDLESS of what the database says. This handles
# two scenarios cleanly:
#
#   1. No DB row yet (first sign-in before lazy-provision):
#      The override grants platform_admin without touching the DB.
#
#   2. Existing row with a stale/wrong role (e.g. internal_consultant
#      from an earlier lazy-provision run):
#      The override STILL promotes the user — the DB row is ignored.
#
# Leave blank (or delete this line) in production. The override only
# fires when this variable is non-empty and the signed-in user's email
# matches (case-insensitive).
#
# To make the promotion permanent, apply the seed SQL at the bottom of
# supabase/migrations/0001_user_profiles.sql in the Supabase SQL editor.
# After that, the env-var override becomes redundant and can be removed.
VITE_PLATFORM_ADMIN_EMAIL=
